# Gravity — all keys optional: without them the app runs in MOCK mode
# (full demo on cached fixtures; real calls switch on per-key)

ANTHROPIC_API_KEY=          # Claude — optional even in live mode: the crew
                            # runs as managed agents (Agent SDK) and can ride
                            # a Claude subscription login / setup-token
APIFY_TOKEN=                # LinkedIn + X actors (harvestapi, apidojo, xquik)
XAI_API_KEY=                # xAI x_search (Agent Tools on /v1/responses)
X_API_KEY=                  # official X API (optional — Apify X actors run
                            # first when APIFY_TOKEN is set; often cheaper)
FULLENRICH_API_KEY=         # REST fallback; MCP uses OAuth (no key)
SILLAGE_API_KEY=            # sk_live_ REST fallback; MCP uses OAuth
HUBSPOT_TOKEN=              # private-app token — pull the pipe (deals)
GRADIUM_API_KEY=            # speech-to-text for podcast/video listening
GRAVITY_MOCK=               # set to 1 to force the cached demo world
